# Server
SERVER_PORT=8080
SERVER_PREFORK=false

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=onedrive
DB_PASSWORD=onedrive_secret_2026
DB_NAME=onedrive
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Ho_Chi_Minh

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_2026
REDIS_DB=0

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-random-string-64-chars-minimum
JWT_REFRESH_SECRET=change-me-refresh-secret-random-string-64-chars-minimum
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGINS=http://localhost:3000

# Argon2
ARGON2_MEMORY=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=4
ARGON2_SALT_LENGTH=16
ARGON2_KEY_LENGTH=32

# App
APP_NAME=1Drive
APP_ENV=development

# Backblaze B2 (S3-Compatible)
B2_KEY_ID=your_b2_application_key_id
B2_APP_KEY=your_b2_application_key
B2_BUCKET_NAME=your_bucket_name
B2_REGION=us-west-004
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
